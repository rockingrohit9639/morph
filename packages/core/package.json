{
	"name": "@morph-ui/core",
	"version": "0.0.1",
	"description": "Framework-agnostic frecency engine for adaptive UIs",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts",
		"dev": "tsup src/index.ts --format esm --dts --watch",
		"test": "vitest",
		"lint": "tsc --noEmit",
		"check": "biome check ."
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.5.0",
		"vitest": "^3.0.0"
	},
	"license": "MIT"
}
