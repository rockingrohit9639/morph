{
  "name": "@morph-sdk/core",
  "version": "0.1.0",
  "description": "Framework-agnostic frecency engine for adaptive UIs",
  "author": "Rohit Kumar Saini",
  "keywords": ["frecency", "adaptive-ui", "user-preferences", "personalization", "localStorage", "ui"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rockingrohit9639/morph.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/rockingrohit9639/morph#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "check": "biome check ."
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
